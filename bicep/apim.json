    },
    "apimPrivateIp": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ApiManagement/service', variables('apimUniqueName')), '2024-06-01-preview').privateIPAddresses[0]]"
    },
    "apimPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ApiManagement/service', variables('apimUniqueName')), '2024-06-01-preview', 'full').identity.principalId]"
    },
    "foundryEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.cognitiveservices.azure.com', variables('aiServicesUniqueName'))]"
    }
  }
}