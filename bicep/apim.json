    "vnetName": {
      "type": "string",
      "defaultValue": "vnet-foundry-test",
      "metadata": {
        "description": "Existing VNet name (from main.bicep)"
      }
    },
    "apimSubnetName": {
      "type": "string",
      "defaultValue": "snet-apim",
