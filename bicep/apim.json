        "description": "APIM subnet configuration"
      }
    },
    "apimSubnetPrefix": {
      "type": "string",
      "defaultValue": "192.168.2.0/27"
    },
    "aiServicesNamePrefix": {
      "type": "string",
      "defaultValue": "ai-foundry-byovnet",
      "metadata": {
        "description": "Foundry account name prefix (must match main.bicep)"
