# ============================================================
# Foundry Enterprise Workshop — konfiguracja środowiska
# ============================================================
# 1. Skopiuj ten plik:  cp .env.example .env
# 2. Uzupełnij wartości
# 3. Załaduj:  Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }
# ============================================================

# === Azure Subscription ===
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=rg-foundry-byovnet
AZURE_LOCATION=swedencentral

# === VM Jumpbox ===
VM_ADMIN_PASSWORD=YourStrongPassword123!

# === Lab User (Faza 7b — multi-tenant isolation) ===
LAB_USER_PASSWORD=YourLabUserPassword123!
LAB_USER_UPN=userlab01@yourdomain.onmicrosoft.com
